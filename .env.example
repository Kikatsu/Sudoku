# --- Browser (Vite) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
# App origin for Polar return URLs (match POLAR_SUCCESS_URL host)
VITE_APP_ORIGIN=http://localhost:5173
# Only if the API is on another origin (e.g. local `vite` + API elsewhere). On Vercel leave empty.
# VITE_API_BASE=

# --- Vercel → Project Settings → Environment Variables ---
# SUPABASE_URL=                 # same as VITE_SUPABASE_URL
# SUPABASE_ANON_KEY=            # publishable or anon JWT (verify user JWT in polar-checkout)
# SUPABASE_SERVICE_ROLE_KEY=    # server only — updates profiles from polar-webhook
# POLAR_ACCESS_TOKEN=
# POLAR_PRODUCT_ID=             # or comma-separated POLAR_PRODUCT_IDS
# POLAR_API_BASE=https://api.polar.sh
# POLAR_SUCCESS_URL=https://your-app.vercel.app/#/
# POLAR_RETURN_URL=             # optional
# POLAR_WEBHOOK_SECRET=

# Polar webhook URL (production):
# https://your-app.vercel.app/api/polar-webhook

# Local full stack: `vercel dev` (serves Vite + /api on one port)
