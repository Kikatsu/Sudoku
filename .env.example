# --- Browser (Vite) ---
# VITE_* values are bundled into the public website. Never put service-role keys,
# Polar access tokens, webhook secrets, database passwords, or private API keys here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
# App origin for production return URLs (match Supabase Auth redirects and Polar return URLs)
VITE_APP_ORIGIN=http://localhost:5173
# Only if the API is on another origin (e.g. local `vite` + API elsewhere). On Vercel leave empty.
# VITE_API_BASE=

# --- Vercel -> Project Settings -> Environment Variables ---
# Keep these server-only. Do not prefix secrets with VITE_ and do not commit real values.
APP_ORIGIN=https://sudocore.vercel.app
# Optional comma-separated list when you need multiple trusted browser origins.
# POLAR_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
# SUPABASE_URL=                 # same as VITE_SUPABASE_URL
# SUPABASE_ANON_KEY=            # publishable or anon JWT (verify user JWT in polar-checkout)
# SUPABASE_SERVICE_ROLE_KEY=    # server only - updates profiles from polar-webhook
# POLAR_ACCESS_TOKEN=
# POLAR_PRODUCT_ID=             # or comma-separated POLAR_PRODUCT_IDS
# POLAR_API_BASE=https://api.polar.sh
# POLAR_SUCCESS_URL=https://your-app.vercel.app/#/
# POLAR_RETURN_URL=             # optional
# POLAR_WEBHOOK_SECRET=

# Polar webhook URL (production):
# https://your-app.vercel.app/api/polar-webhook
# Subscribe the webhook to:
# customer.state_changed, subscription.active, subscription.updated,
# subscription.canceled, subscription.uncanceled, subscription.past_due,
# subscription.revoked

# Local full stack: `vercel dev` (serves Vite + /api on one port)
